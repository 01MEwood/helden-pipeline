# =====================================================================
# Environment Variables für den Hostinger Stack
# =====================================================================
# Im Hostinger Docker Manager unter "Environment" eintragen
# (NICHT als .env-Datei committen!)
# =====================================================================

# --- Datenbank ---
# Postgres erlaubt keine Bindestriche in DB-/User-Namen → Underscore verwenden
DB_NAME=helden_pipeline
DB_USER=helden_pipeline_user
DB_PASSWORD=CHANGE_ME_strong_password_here

# --- Backend ---
JWT_SECRET=CHANGE_ME_random_64_char_string
NODE_ENV=production
# Modul-spezifischer Backend-Port (siehe MEOS-Konvention im Template-README)
# helden-pipeline = 4100
PORT=4100

# --- Frontend (build-time, in GitHub Actions als BUILD ARG gesetzt) ---
# Diese Variable wird NICHT im Hostinger gebraucht — sie wird beim
# docker build im GitHub Actions Workflow in den Bundle gebacken.
VITE_API_URL=https://helden-pipeline.meosapp.de/api
